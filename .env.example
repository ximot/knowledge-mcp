# =============================================================================
# Knowledge MCP Server — Configuration
# =============================================================================
# Copy this file to .env and adjust as needed.
# All values below are defaults — uncomment and change only what you need.

# --- Qdrant Vector Database ---
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_API_KEY=              # Optional: API key for Qdrant Cloud or secured instances
# QDRANT_HTTPS=false           # Set to true for Qdrant Cloud

# --- Ollama (Embeddings) ---
# OLLAMA_HOST=http://localhost:11434
# EMBEDDING_MODEL=nomic-embed-text
# VECTOR_SIZE=768              # Must match the embedding model dimension

# --- MCP Server ---
# MCP_HOST=0.0.0.0
# MCP_PORT=8765
